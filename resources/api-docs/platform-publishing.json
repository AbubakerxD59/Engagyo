[
    {
        "id": "facebook",
        "name": "Facebook",
        "media": [
            {
                "id": "text-link",
                "label": "Text / link post",
                "supported": true,
                "description": "Link-style Page post via POST /posts. The API expects image_url (preview image) plus title/description for the message; set link to the destination URL.",
                "http_method": "POST",
                "http_path": "/posts",
                "hide_copy_url": false,
                "request": {
                    "headers": {
                        "Authorization": "Bearer your_api_key_here",
                        "Content-Type": "application/json"
                    },
                    "body": {
                        "platform": "facebook",
                        "account_id": "123456789012345",
                        "image_url": "https://example.com/images/link-preview.jpg",
                        "title": "Read our latest update",
                        "description": "Optional longer copy for the post body.",
                        "link": "https://example.com/blog/post",
                        "publish_now": 1
                    },
                    "curl": "curl -X POST \"{base_url}/posts\" \\\\n  -H \"Authorization: Bearer your_api_key_here\" \\\\n  -H \"Content-Type: application/json\" \\\\n  -d '{\"platform\":\"facebook\",\"account_id\":\"123456789012345\",\"image_url\":\"https://example.com/images/link-preview.jpg\",\"title\":\"Read our latest\",\"link\":\"https://example.com/blog/post\",\"publish_now\":1}'"
                },
                "response": {
                    "success": true,
                    "message": "Post is being published",
                    "data": {
                        "post": {
                            "id": 123,
                            "platform": "facebook",
                            "status": "publishing",
                            "type": "photo",
                            "created_at": "2025-12-04T10:30:00+00:00"
                        },
                        "account": {
                            "type": "facebook_page",
                            "page_id": "123456789012345",
                            "name": "My Business Page",
                            "profile_image": "https://example.com/fb-profile.jpg"
                        }
                    }
                },
                "notes": "account_id is the Facebook Page id (GET /user/pages)."
            },
            {
                "id": "photo",
                "label": "Photo post",
                "supported": true,
                "description": "Single-image Page post: image_url plus title (and optional description).",
                "http_method": "POST",
                "http_path": "/posts",
                "hide_copy_url": false,
                "request": {
                    "headers": {
                        "Authorization": "Bearer your_api_key_here",
                        "Content-Type": "application/json"
                    },
                    "body": {
                        "platform": "facebook",
                        "account_id": "123456789012345",
                        "image_url": "https://example.com/images/promo.jpg",
                        "title": "Summer sale",
                        "description": "Optional caption.",
                        "publish_now": 1
                    },
                    "curl": "curl -X POST \"{base_url}/posts\" \\\\n  -H \"Authorization: Bearer your_api_key_here\" \\\\n  -H \"Content-Type: application/json\" \\\\n  -d '{\"platform\":\"facebook\",\"account_id\":\"123456789012345\",\"image_url\":\"https://example.com/images/promo.jpg\",\"title\":\"Summer sale\",\"publish_now\":1}'"
                },
                "response": {
                    "success": true,
                    "message": "Post is being published",
                    "data": {
                        "post": {
                            "id": 123,
                            "platform": "facebook",
                            "status": "publishing",
                            "type": "photo",
                            "created_at": "2025-12-04T10:30:00+00:00"
                        },
                        "account": {
                            "type": "facebook_page",
                            "page_id": "123456789012345",
                            "name": "My Business Page",
                            "profile_image": "https://example.com/fb-profile.jpg"
                        }
                    }
                },
                "notes": null
            },
            {
                "id": "video-feed",
                "label": "Video (feed)",
                "supported": true,
                "description": "Feed video: server downloads video_url, validates MIME, stores on S3, then publishes.",
                "http_method": "POST",
                "http_path": "/posts/video",
                "hide_copy_url": false,
                "request": {
                    "headers": {
                        "Authorization": "Bearer your_api_key_here",
                        "Content-Type": "application/json"
                    },
                    "body": {
                        "platform": "facebook",
                        "account_id": "123456789012345",
                        "video_url": "https://example.com/videos/promo.mp4",
                        "title": "Product demo",
                        "description": "Optional",
                        "publish_now": 1
                    },
                    "curl": "curl -X POST \"{base_url}/posts/video\" \\\\n  -H \"Authorization: Bearer your_api_key_here\" \\\\n  -H \"Content-Type: application/json\" \\\\n  -d '{\"platform\":\"facebook\",\"account_id\":\"123456789012345\",\"video_url\":\"https://example.com/videos/promo.mp4\",\"title\":\"Product demo\",\"publish_now\":1}'"
                },
                "response": {
                    "success": true,
                    "message": "Video is being published",
                    "data": {
                        "post": {
                            "id": 125,
                            "platform": "instagram",
                            "status": "publishing",
                            "type": "video",
                            "created_at": "2025-12-04T10:30:00+00:00"
                        },
                        "account": {
                            "type": "instagram",
                            "ig_user_id": "17841400000000000",
                            "username": "mybrand",
                            "name": "My Brand",
                            "profile_image": "https://example.com/ig.jpg"
                        }
                    }
                },
                "notes": "Supported types include mp4, mov, avi, mkv, webm (by MIME)."
            }
        ]
    },
